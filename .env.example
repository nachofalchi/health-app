NEXT_PUBLIC_SITE_URL=https://salud-nacho.vercel.app
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Private Postgres connection string for local SQL queries and migrations.
# Never expose this as NEXT_PUBLIC_*. Keep it local/Vercel private.
SUPABASE_DB_URL=
# Local-only convenience: when true, server routes may use the single Google-connected user if no browser session is present.
ALLOW_SINGLE_USER_FALLBACK=

# Protects manual sync endpoints until Vercel Cron or a better job runner is added.
SYNC_SECRET=
OAUTH_STATE_SECRET=
TOKEN_ENCRYPTION_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
